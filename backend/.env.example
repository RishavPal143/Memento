# PostgreSQL Connection Configuration
# Replace 'yourpassword' with your actual PostgreSQL password.
# Replace 'postgres' at the end with your target database name if needed.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/postgres

# AI Provider Configuration ("openai", "gemini", or "mock" for local testing)
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

# OpenAI Settings (required if using "openai" provider)
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Gemini Settings (required if using "gemini" provider)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_CHAT_MODEL=gemini-1.5-flash

# Intelligence Layer Settings (background task interval in seconds, default: 600)
INTELLIGENCE_INTERVAL_SECONDS=600

