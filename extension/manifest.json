{
  "manifest_version": 3,
  "name": "Internet Memory",
  "version": "1.0.0",
  "description": "Automatically captures and saves webpages you visit to your Internet Memory PostgreSQL database.",
  "permissions": [
    "tabs"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
